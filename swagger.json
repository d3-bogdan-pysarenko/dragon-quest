                "popularity": 1
              }
            ]
          }
        },
        "RatingRequest": {
          "type": "object",
          "required": ["rate", "email"],
          "properties": {
            "rate": {
              "type": "number",
              "description": "Exercise's rating",
              "example": 5
            },
            "email": {
              "type": "string",
              "description": "User's email",
              "example": "test@gmail.com"
            },
            "review": {
              "type": "string",
              "description": "User's review",
              "example": "My best exercise"
            }
          }
        },
        "ExerciseResponse": {
          "type": "object",
          "properties": {
            "_id": {
              "type": "string",
              "description": "Exercise's id",
              "format": "64f389465ae26083f39b17a6"
            },
            "bodyPart": {
              "type": "string",
              "description": "Body part is involved in the exercise",
              "example": "back"
            },
            "equipment": {
              "type": "string",
              "description": "Equipment is involved in the exercise",
              "example": "cable"
            },
            "gifUrl": {
              "type": "string",
              "description": "Exercise's gif URL",
              "example": "https://ftp.goit.study/img/power-pulse/gifs/0007.gif"
            },
            "name": {
              "type": "string",
              "description": "Exercise's name",
              "example": "alternate lateral pulldown"
            },
            "target": {
