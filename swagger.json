            },
            "results": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "filter": {
                    "type": "string",
                    "description": "Exercise's filter",
                    "example": "Body parts"
                  },
                  "name": {
                    "type": "string",
                    "description": "Filter's item",
                    "example": "back"
                  },
                  "imgUrl": {
                    "type": "string",
                    "description": "Filter's img URL",
                    "example": "string"
                  }
                }
              }
            }
          },
          "example": {
            "page": 1,
            "perPage": 12,
            "totalPages": 5,
            "results": [
              {
                "filter": "Body parts",
