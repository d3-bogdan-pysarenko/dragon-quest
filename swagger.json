{
  "swaggerDoc": {
    "openapi": "3.0.1",
    "info": {
      "version": "1.0.1",
      "title": "API Your Energy",
      "description": "The API for the Your Energy project"
    },
    "consumes": ["application/json"],
    "produces": ["application/json"],
    "servers": [
      {
        "url": "https://your-energy.b.goit.study/api"
      }
    ],
    "tags": [
      {
        "name": "Exercises",
        "description": "Exercises endpoints"
      },
      {
        "name": "Filters",
        "description": "Filters endpoints"
      },
      {
        "name": "Quotes",
        "description": "Quotes endpoints"
      },
      {
        "name": "Subscriptions",
        "description": "Subscriptions endpoints"
      }
    ],
    "paths": {
      "/exercises": {
        "get": {
          "tags": ["Exercises"],
          "summary": "Get Exercises By Filters",
          "parameters": [
            {
              "name": "bodypart",
              "in": "query",
              "schema": {
                "type": "string",
                "enum": [
                  "back",
                  "cardio",
                  "chest",
                  "lower arms",
                  "lower legs",
                  "neck",
                  "shoulders",
                  "upper arms",
                  "upper legs",
                  "waist"
                ]
              },
              "description": "Select body part for search exercises by body part"
            },
            {
              "name": "muscles",
              "in": "query",
              "description": "Select muscle for search exercises by muscle",
              "schema": {
                "type": "string",
                "enum": [
                  "abductors",
                  "abs",
                  "adductors",
                  "biceps",
                  "calves",
                  "cardiovascular system",
                  "delts",
                  "forearms",
                  "glutes",
                  "hamstrings",
                  "lats",
                  "levator scapulae",
                  "pectorals",
                  "quads",
                  "serratus anterior",
                  "spine",
                  "traps",
                  "triceps",
                  "upper back"
                ]
              }
            },
            {
              "name": "equipment",
              "in": "query",
              "description": "Select equipment for search exercises by equipment",
              "schema": {
                "type": "string",
                "enum": [
                  "assisted",
                  "band",
                  "barbell",
                  "body weight",
                  "bosu ball",
                  "cable",
                  "dumbbell",
                  "elliptical machine",
                  "ez barbell",
                  "hammer",
                  "kettlebell",
                  "leverage machine",
                  "medicine ball",
                  "olympic barbell",
                  "resistance band",
                  "roller",
                  "rope",
                  "skierg machine",
                  "sled machine",
                  "smith machine",
                  "stability ball",
                  "stationary bike",
                  "stepmill machine",
                  "tire",
                  "trap bar",
                  "upper body ergometer",
                  "weighted",
                  "wheel roller"
                ]
              }
            },
            {
              "in": "query",
              "name": "keyword",
              "description": "Input keyword for search by exercise name",
              "schema": {
                "type": "string"
              }
            },
            {
              "in": "query",
              "name": "page",
              "description": "Input number page of the exercises",
              "schema": {
                "type": "number",
                "default": 1
              }
            },
            {
              "in": "query",
              "name": "limit",
              "description": "Input limit for the exercises",
              "schema": {
                "type": "number",
                "default": 10
              }
            }
          ],
          "responses": {
            "200": {
              "description": "Successful operation",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/ExercisesResponse"
                  }
                }
              }
            },
            "404": {
              "description": "Not found",
              "content": {}
            },
            "409": {
              "description": "Filter is required",
              "content": {}
            },
            "500": {
              "description": "Server error",
              "content": {}
            }
          }
        }
      },
      "/exercises/{id}/rating": {
        "patch": {
          "tags": ["Exercises"],
          "summary": "Add Exercise's Rating",
          "parameters": [
            {
              "in": "path",
              "name": "id",
              "schema": {
                "type": "string"
              },
              "required": true
            }
          ],
          "requestBody": {
            "description": "Rating's object",
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RatingRequest"
                }
              }
            }
          },
          "responses": {
            "200": {
              "description": "Successful operation",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/ExerciseResponse"
                  }
                }
              }
            },
            "400": {
              "description": "Bad request (invalid request body)",
              "content": {}
            },
            "404": {
              "description": "Such exercise not found",
              "content": {}
            },
            "409": {
              "description": "Such email already exists",
              "content": {}
            },
            "500": {
              "description": "Server error",
              "content": {}
            }
          }
        }
      },
      "/exercises/{id}": {
        "get": {
          "tags": ["Exercises"],
          "summary": "Get Exercise By Id",
          "parameters": [
            {
              "in": "path",
              "name": "id",
              "schema": {
                "type": "string"
              },
              "required": true
            }
          ],
          "responses": {
            "200": {
              "description": "Successful operation",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/ExerciseResponse"
                  }
                }
              }
            },
            "400": {
              "description": "Bad request (invalid request body)",
              "content": {}
            },
            "404": {
              "description": "Not found",
              "content": {}
            },
            "500": {
              "description": "Server error",
              "content": {}
            }
          }
        }
      },
      "/filters": {
        "get": {
          "tags": ["Filters"],
          "summary": "Get Filters Of Exercises",
          "parameters": [
            {
              "name": "filter",
              "in": "query",
              "schema": {
                "type": "string",
                "enum": ["Body parts", "Muscles", "Equipment"]
              },
              "description": "Select filter for search exercises"
            },
            {
              "in": "query",
              "name": "page",
              "description": "Input number page of the exercises",
              "schema": {
                "type": "number",
                "default": 1
              }
            },
            {
              "in": "query",
              "name": "limit",
              "description": "Input limit for the exercises",
              "schema": {
                "type": "number",
                "default": 12
              }
            }
          ],
          "responses": {
            "200": {
              "description": "Successful operation",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/FiltersResponse"
                  }
                }
              }
            },
            "404": {
              "description": "Not found",
              "content": {}
            },
            "500": {
              "description": "Server error",
              "content": {}
            }
          }
        }
      },
      "/quote": {
        "get": {
          "tags": ["Quotes"],
          "summary": "Get Quote of the day",
          "responses": {
            "200": {
              "description": "Successful operation",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/QuoteResponse"
                  }
                }
              }
            },
            "404": {
              "description": "Not found",
              "content": {}
            },
            "500": {
              "description": "Server error",
              "content": {}
            }
          }
        }
      },
      "/subscription": {
        "post": {
          "tags": ["Subscriptions"],
          "summary": "Order subscription to new exercises",
          "requestBody": {
            "description": "Subscription's object",
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SubscriptionRequest"
                }
              }
            }
          },
          "responses": {
            "201": {
              "description": "Successful operation",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/SubscriptionResponse"
                  }
                }
              }
            },
            "400": {
              "description": "Bad request (invalid request body)",
              "content": {}
            },
            "404": {
              "description": "Not found",
              "content": {}
            },
            "409": {
              "description": "Subscription already exists",
              "content": {}
            },
            "500": {
              "description": "Server error",
              "content": {}
            }
          }
        }
      }
    },
    "components": {
      "schemas": {
        "ExercisesResponse": {
          "type": "object",
          "properties": {
            "page": {
              "type": "number",
              "description": "Page number",
              "format": 1
            },
            "perPage": {
              "type": "number",
              "description": "Number of items per page",
              "format": 6
            },
            "totalPages": {
              "type": "number",
              "description": "Total number of pages",
              "format": 48
            },
            "results": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "_id": {
                    "type": "string",
                    "description": "Exercise's id",
                    "format": "64f389465ae26083f39b17a6"
                  },
                  "bodyPart": {
                    "type": "string",
                    "description": "Body part is involved in the exercise",
                    "example": "back"
                  },
                  "equipment": {
                    "type": "string",
                    "description": "Equipment is involved in the exercise",
                    "example": "cable"
                  },
                  "gifUrl": {
                    "type": "string",
                    "description": "Exercise's gif URL",
                    "example": "https://ftp.goit.study/img/power-pulse/gifs/0007.gif"
                  },
                  "name": {
                    "type": "string",
                    "description": "Exercise's name",
                    "example": "alternate lateral pulldown"
                  },
                  "target": {
                    "type": "string",
                    "description": "Exercise's target (muscle)",
                    "example": "lats"
                  },
                  "description": {
                    "type": "string",
                    "description": "Exercise's description",
                    "example": "These large back muscles are responsible for shoulder adduction and horizontal extension. Pull-ups and lat pulldowns are common exercises targeting the lats."
                  },
                  "rating": {
                    "type": "number",
                    "description": "Exercise's rating",
                    "example": 3
                  },
                  "burnedCalories": {
                    "type": "number",
                    "description": "The number of calories burned in a given time",
                    "example": 70
                  },
                  "time": {
                    "type": "number",
                    "description": "Exercise time for burning certain calories",
                    "example": 3
                  },
                  "popularity": {
                    "type": "number",
                    "description": "Exercise's popularity",
                    "example": 100
                  }
                }
              }
            }
          },
          "example": {
            "page": 1,
            "perPage": 6,
            "totalPages": 1,
            "results": [
